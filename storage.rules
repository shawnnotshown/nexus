rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isWorkspaceOwner(workspaceId) {
      return firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)).data.createdBy == request.auth.uid
        || (
          firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid))
          && firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role == 'owner'
        );
    }

    function isOnProjectTeam(workspaceId, projectId) {
      return request.auth.uid in firestore.get(
        /databases/(default)/documents/workspaces/$(workspaceId)/projects/$(projectId)
      ).data.team;
    }

    function canAccessProject(workspaceId, projectId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid))
        && (isWorkspaceOwner(workspaceId) || isOnProjectTeam(workspaceId, projectId));
    }

    match /workspaces/{workspaceId}/projects/{projectId}/{fileName} {
      allow read: if canAccessProject(workspaceId, projectId);

      allow write: if canAccessProject(workspaceId, projectId)
        && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
