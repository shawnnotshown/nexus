rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isWorkspaceMember(workspaceId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId} {
      allow read: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        isWorkspaceMember(workspaceId)
      );

      allow create: if request.auth != null
        && request.auth.uid == workspaceId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'createdAt', 'createdBy']);

      allow update: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        isWorkspaceMember(workspaceId)
      );

      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      match /members/{userId} {
        allow read: if isWorkspaceMember(workspaceId);

        allow create: if request.auth != null
          && request.auth.uid == userId
          && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.createdBy == request.auth.uid;

        allow update, delete: if isWorkspaceMember(workspaceId) && request.auth.uid == userId;
      }

      match /projects/{projectId} {
        allow read, write: if isWorkspaceMember(workspaceId);

        match /todoLists/{listId} {
          allow read, write: if isWorkspaceMember(workspaceId);
        }

        match /todoItems/{itemId} {
          allow read, write: if isWorkspaceMember(workspaceId);
        }

        match /boardThreads/{threadId} {
          allow read: if isWorkspaceMember(workspaceId);
          allow create: if isWorkspaceMember(workspaceId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.keys().hasAll(['title', 'content', 'userId', 'createdAt', 'commentCount']);
          allow update, delete: if isWorkspaceMember(workspaceId);

          match /comments/{commentId} {
            allow read: if isWorkspaceMember(workspaceId);
            allow create: if isWorkspaceMember(workspaceId)
              && request.resource.data.userId == request.auth.uid
              && request.resource.data.keys().hasAll(['userId', 'content', 'createdAt']);
            allow update, delete: if isWorkspaceMember(workspaceId)
              && resource.data.userId == request.auth.uid;
          }
        }

        match /files/{fileId} {
          allow read, write: if isWorkspaceMember(workspaceId);
        }

        match /scheduleEvents/{eventId} {
          allow read, write: if isWorkspaceMember(workspaceId);
        }
      }

      match /tasks/{taskId} {
        allow read, write: if isWorkspaceMember(workspaceId);
      }

      match /messages/{messageId} {
        allow read: if isWorkspaceMember(workspaceId);

        allow create: if isWorkspaceMember(workspaceId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.keys().hasAll(['channelId', 'userId', 'content', 'createdAt']);

        allow update, delete: if isWorkspaceMember(workspaceId);
      }
    }
  }
}
