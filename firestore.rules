rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isWorkspaceMember(workspaceId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function memberData(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data;
    }

    function isWorkspaceOwner(workspaceId) {
      return request.auth != null
        && (
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.createdBy == request.auth.uid
          || (
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid))
            && memberData(workspaceId).role == 'owner'
          )
        );
    }

    function projectTeamList(workspaceId, projectId) {
      let team = get(/databases/$(database)/documents/workspaces/$(workspaceId)/projects/$(projectId)).data.team;
      return team is list ? team : [];
    }

    function isOnProjectTeam(workspaceId, projectId) {
      return request.auth.uid in projectTeamList(workspaceId, projectId);
    }

    function isOnResourceProjectTeam() {
      return resource.data.team is list
        && request.auth.uid in resource.data.team;
    }

    function canAccessProject(workspaceId, projectId) {
      return isWorkspaceOwner(workspaceId) || isOnProjectTeam(workspaceId, projectId);
    }

    function canAccessTaskProject(workspaceId) {
      return resource.data.projectId is string
        && canAccessProject(workspaceId, resource.data.projectId);
    }

    function incomingTaskProjectId(workspaceId) {
      return request.resource.data.projectId;
    }

    function canAccessIncomingTaskProject(workspaceId) {
      return incomingTaskProjectId(workspaceId) is string
        && canAccessProject(workspaceId, incomingTaskProjectId(workspaceId));
    }

    function isWorkspaceChannel(channelId) {
      return channelId == 'general'
        || channelId == 'design-updates'
        || channelId == 'feature-requests';
    }

    function isDmChannelForUser(channelId) {
      return channelId is string && (
        channelId.matches('dm:' + request.auth.uid + ':[^:]+')
        || channelId.matches('dm:[^:]+:' + request.auth.uid)
      );
    }

    function canReadMessage(workspaceId) {
      let channelId = resource.data.channelId;
      return channelId is string && (
        isWorkspaceChannel(channelId)
        || isDmChannelForUser(channelId)
        || isWorkspaceOwner(workspaceId)
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId} {
      allow read: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        isWorkspaceMember(workspaceId)
      );

      allow create: if request.auth != null
        && request.auth.uid == workspaceId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'createdAt', 'createdBy']);

      allow update: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        isWorkspaceMember(workspaceId)
      );

      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      match /members/{userId} {
        allow read: if isWorkspaceMember(workspaceId);

        allow create: if request.auth != null
          && request.auth.uid == userId
          && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.createdBy == request.auth.uid;

        allow update, delete: if isWorkspaceMember(workspaceId) && request.auth.uid == userId;
      }

      match /projects/{projectId} {
        // Owners (workspace creator) may list all projects even before their member doc exists.
        allow read: if isWorkspaceOwner(workspaceId)
          || (isWorkspaceMember(workspaceId) && isOnResourceProjectTeam());

        allow create: if isWorkspaceOwner(workspaceId)
          && request.resource.data.keys().hasAll(['name', 'description', 'progress', 'team'])
          && request.auth.uid in request.resource.data.team;

        allow update, delete: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);

        match /todoLists/{listId} {
          allow read, write: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
        }

        match /todoItems/{itemId} {
          allow read, write: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
        }

        match /boardThreads/{threadId} {
          allow read: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
          allow create: if isWorkspaceMember(workspaceId)
            && canAccessProject(workspaceId, projectId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.keys().hasAll(['title', 'content', 'userId', 'createdAt', 'commentCount']);
          allow update, delete: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);

          match /comments/{commentId} {
            allow read: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
            allow create: if isWorkspaceMember(workspaceId)
              && canAccessProject(workspaceId, projectId)
              && request.resource.data.userId == request.auth.uid
              && request.resource.data.keys().hasAll(['userId', 'content', 'createdAt']);
            allow update, delete: if isWorkspaceMember(workspaceId)
              && canAccessProject(workspaceId, projectId)
              && resource.data.userId == request.auth.uid;
          }
        }

        match /files/{fileId} {
          allow read, write: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
        }

        match /scheduleEvents/{eventId} {
          allow read, write: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
        }
      }

      match /tasks/{taskId} {
        allow read: if isWorkspaceMember(workspaceId) && canAccessTaskProject(workspaceId);
        allow create: if isWorkspaceMember(workspaceId) && canAccessIncomingTaskProject(workspaceId);
        allow update, delete: if isWorkspaceMember(workspaceId) && canAccessTaskProject(workspaceId);
      }

      match /messages/{messageId} {
        allow read: if isWorkspaceMember(workspaceId) && canReadMessage(workspaceId);

        allow create: if isWorkspaceMember(workspaceId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.keys().hasAll(['channelId', 'userId', 'content', 'createdAt'])
          && (
            isWorkspaceChannel(request.resource.data.channelId)
            || isDmChannelForUser(request.resource.data.channelId)
            || isWorkspaceOwner(workspaceId)
          );

        allow update, delete: if isWorkspaceMember(workspaceId);
      }

      match /projectInvites/{inviteId} {
        allow read, write: if false;
      }
    }
  }
}
